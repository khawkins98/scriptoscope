# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo
# ...but DO track the committed sit-wasm WASM build, so consumers never need Emscripten
# (only rebuilding does — see tools/sit-wasm/build.sh).
!tools/sit-wasm/dist/
!tools/sit-wasm/dist/**

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Editors / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Claude Code local state (per-user settings + run lock — never shared)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage / test artifacts
coverage/
test-results/
playwright-report/
playwright/.cache/

# Environment
.env
.env.local
.env.*.local

# Research scratch — period theme binaries kept locally for deconstruction.
# See docs/RESEARCH-SPIKE-THEMES.md. Never committed to git.
.scratch/
.gstack/

# Generated diagnostic renders (regenerable via npm run diag:render)
themes/*/diag/

# Option A (2026-05-29) — bundles ship ONLY the source-of-truth files (scheme.sit /
# scheme.rsrc / meta.json / PROVENANCE.md). Pre-extracted derivatives are produced
# on-demand by `npm run build:themes` / `extract-scheme` but stay out of git, since
# the runtime decodes from the original archive in-browser. Re-bake locally any time
# you need them for `lint:themes` / `audit-placement` / `diag:render`.
themes/*/theme.json
themes/*/extraction-manifest.json
themes/*/rasters.json
themes/*/resource-roles.json
themes/*/cicns/
themes/*/ppats/
themes/*/icons/
themes/*/icl4/
themes/*/icl8/
themes/*/ics4/
themes/*/ics8/

# verify-scenes scratch directory
.tmp/
