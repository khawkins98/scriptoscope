{
  "name": "aaron-ui",
  "version": "0.0.0",
  "private": true,
  "description": "A Mac OS Appearance-style window manager and theme engine for the web. Extracted from classic-vibe-mac (see PRD.md).",
  "license": "UNLICENSED",
  "homepage": "https://github.com/khawkins98/aaron-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/khawkins98/aaron-ui.git"
  },
  "bugs": {
    "url": "https://github.com/khawkins98/aaron-ui/issues"
  },
  "keywords": [
    "mac-os",
    "platinum",
    "window-manager",
    "ui",
    "theme",
    "retro",
    "system-7",
    "mac-os-8",
    "kaleidoscope"
  ],
  "type": "module",
  "main": "./dist/aaron-ui.js",
  "module": "./dist/aaron-ui.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/aaron-ui.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "PRD.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
